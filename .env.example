# Supabase (obligatoire)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Branding par défaut (avant /setup ou sans base configurée)
NEXT_PUBLIC_APP_NAME=Workspace
NEXT_PUBLIC_APP_SHORT_NAME=Workspace
NEXT_PUBLIC_APP_TAGLINE=
NEXT_PUBLIC_APP_MARK_SRC=/app-mark.svg
NEXT_PUBLIC_APP_PRIMARY_COLOR=#2563eb
NEXT_PUBLIC_APP_LOCALE=fr
NEXT_PUBLIC_APP_TIMEZONE=Europe/Paris

# Optionnel — alias rétro-compatible pour le pictogramme
# NEXT_PUBLIC_IDENA_MARK_SRC=/app-mark.svg

# Optionnel — IA (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optionnel — LinkedIn (statistiques followers)
NEXT_PUBLIC_LINKEDIN_COMPANY_URL=

# Optionnel — Microsoft 365 / Outlook
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REDIRECT_URI=
MS_TIMEZONE=Europe/Paris
MS_OUTLOOK_CATEGORY_NAME=Planification
MS_OUTLOOK_CATEGORY_COLOR=preset1

# Optionnel — alertes stock Slack
SLACK_WEBHOOK_URL=

# Stripe (facturation SaaS — P2)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
# Activé par défaut en production (NODE_ENV=production). Mettre à false pour désactiver.
# En développement : mettre à true pour tester le blocage post-essai.
BILLING_ENFORCEMENT=

# Optionnel — secret pour appels internes (cron, webhooks maison)
# Header : x-internal-secret ou Authorization: Bearer <secret>
# Cron essai : GET /api/cron/trial-reminders (planifié dans vercel.json)
# Sur Vercel : définir CRON_SECRET (envoyé automatiquement par le cron) — peut être identique à INTERNAL_API_SECRET
INTERNAL_API_SECRET=
CRON_SECRET=

# Optionnel — e-mails transactionnels (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Workspace <onboarding@votredomaine.fr>

# Optionnel — super-admin plateforme (emails séparés par des virgules)
PLATFORM_ADMIN_EMAILS=admin@votredomaine.fr

# Optionnel — monitoring erreurs (Sentry)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Optionnel — scripts de migration SQL locaux (npm run db:*)
SUPABASE_DB_PASSWORD=

# Tests d'isolation multi-tenant (npm run test:multi-tenant)
# Requiert un projet Supabase de test — ne pas utiliser la prod sans précaution.
# NEXT_PUBLIC_SUPABASE_URL=...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...
