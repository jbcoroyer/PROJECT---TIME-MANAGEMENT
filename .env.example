# Supabase (obligatoire)
NEXT_PUBLIC_SUPABASE_URL=https://tjzagxyvjnkbwfpsppqw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Application — en local : localhost ; sur Vercel : https://project-time-management.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Branding par défaut (avant /setup)
NEXT_PUBLIC_APP_NAME=Workspace
NEXT_PUBLIC_APP_SHORT_NAME=Workspace
NEXT_PUBLIC_APP_TAGLINE=
NEXT_PUBLIC_APP_MARK_SRC=/app-mark.svg
NEXT_PUBLIC_APP_PRIMARY_COLOR=#2563eb
NEXT_PUBLIC_APP_LOCALE=fr
NEXT_PUBLIC_APP_TIMEZONE=Europe/Paris

# Optionnel — IA (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optionnel — LinkedIn (statistiques followers)
NEXT_PUBLIC_LINKEDIN_COMPANY_URL=

# Optionnel — Microsoft 365 / Outlook (URI callback auto : {APP_URL}/api/outlook/callback)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_TIMEZONE=Europe/Paris
MS_OUTLOOK_CATEGORY_NAME=Planification
MS_OUTLOOK_CATEGORY_COLOR=preset1

# Optionnel — alertes stock Slack
SLACK_WEBHOOK_URL=

# Stripe (facturation)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
# Production : true (défaut). Local : true/false pour tester le blocage post-essai.
BILLING_ENFORCEMENT=

# Cron essai (Vercel) — une seule variable suffit ; les deux acceptent le même secret
CRON_SECRET=
INTERNAL_API_SECRET=

# E-mails transactionnels (Resend) — invitations, rappels essai
RESEND_API_KEY=
RESEND_FROM_EMAIL=Workspace <onboarding@votredomaine.fr>

# Super-admin plateforme (/platform) — votre e-mail de connexion
PLATFORM_ADMIN_EMAILS=

# Monitoring (optionnel)
SENTRY_DSN=

